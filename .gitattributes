# Normalize line endings to LF in the repository;
# Git will convert to CRLF on Windows checkout automatically.
* text=auto eol=lf

# Explicitly mark binary files so Git never modifies them
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.jar  binary
*.class binary
